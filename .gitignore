# ============================================================
# Amplify MVP - .gitignore
# Repo: AI_maketing_da_kenh_web (Next.js + Supabase + Inngest)
# ============================================================

# ---------- Environment & Secrets ----------
# Local env files - NEVER commit real credentials
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
.env.test

# Env templates (only push .env.example)
!.env.example

# Service-account / private keys
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
service-account*.json
gcp-credentials*.json
aws-credentials*
firebase-adminsdk*.json

# Secrets in other forms
secrets/
*.secret
*_secret.*
config.local.*

# ---------- Node / Next.js ----------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Build output
.next/
out/
build/
dist/
.turbo/

# Next.js cache & manifests
*.tsbuildinfo
next-env.d.ts

# ---------- Testing & Coverage ----------
coverage/
.nyc_output/
playwright-report/
test-results/
playwright/.cache/
.vitest-cache/

# ---------- Logs ----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.next/server/logs/

# ---------- Runtime / OS ----------
# OS junk
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# Editor / IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~

# Cursor IDE (local config)
.cursor/
.cursorrules
.cursorignore

# Claude / AI assistant local state
.claude/
.aider*
.continue/

# ---------- Misc ----------
# Local scripts that may contain tokens
scripts/local/
tmp/
temp/

# Misc
*.tgz
.cache/
.parcel-cache/
.eslintcache
.eslintcache.*

# ---------- Database dumps (NEVER commit if contains real data) ----------
*.sql.gz
*.dump
*.bak
*.backup
database/exports/

