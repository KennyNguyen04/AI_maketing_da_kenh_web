# Amplify Frontend Environment Variables
# Copy this file to `.env.local` and fill in real values. Never commit .env.local.
# Server-side validation: see lib/env.ts (validateEnv / assertEnv).

# ============================================
# REQUIRED — Supabase
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key

# ============================================
# REQUIRED — Encryption & AI
# ============================================
# 32+ chars. Used to AES-256-GCM encrypt OAuth tokens at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=replace-me-with-32-plus-random-chars

# Google Gemini API key (gemini-2.5-flash-lite). Free tier: 30 req/min, 1500 req/day.
# Flash-Lite chosen for maximum free-tier headroom across 50+ MVP users.
GOOGLE_AI_API_KEY=your-gemini-api-key

# ============================================
# OPTIONAL — Inngest (background jobs)
# ============================================
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ============================================
# OPTIONAL — X (Twitter) OAuth
# ============================================
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/api/social/x/callback

# ============================================
# OPTIONAL — Facebook OAuth
# ============================================
# Note: Facebook OAuth 2.0 does NOT support PKCE. appsecret_proof (HMAC-SHA256
# of access_token keyed by app_secret) is computed server-side automatically.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/social/facebook/callback

# ============================================
# OPTIONAL — App config
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
